generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}
enum UserRole {
  DIRECTOR
  PRODUCCION
  COCCION
  MOLIENDA
  FERMENTACION
  DESTILACION
  LABORATORIO
  MANTENIMIENTO
  INVENTARIO
  CONSULTA
}

enum EquipmentType {
  HORNO
  DESGARRADORA
  PRENSA
  TINA
  ALAMBIQUE
  BOMBA
  TANQUE
  CALDERA
  OTRO
}

enum EquipmentStatus {
  DISPONIBLE
  OPERANDO
  ESPERANDO
  LAVADO
  MANTENIMIENTO
}

enum LotStage {
  RECEPCION
  COCCION
  MOLIENDA
  FERMENTACION
  DESTILACION
  RECTIFICACION
  TERMINADO
}

model User {
  id       String   @id @default(cuid())
  name     String
  email    String   @unique
  password String
  role     UserRole
  active   Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lots Lot[]
}

model Equipment {
  id     String          @id @default(cuid())
  name   String
  type   EquipmentType
  status EquipmentStatus @default(DISPONIBLE)

  capacity    Float
  currentLoad Float   @default(0)
  unit        String
  location    String?
  active      Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cookings      Cooking[]
  millings      Milling[]
  distillations Distillation[]
}

model Lot {
  id    String   @id @default(cuid())
  code  String   @unique
  stage LotStage

  agaveKg      Float
  art          Float?
  startedAt    DateTime
  finishedAt   DateTime?
  observations String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id])

  cookings      Cooking[]
  millings      Milling[]
  fermentations Fermentation[]
  distillations Distillation[]
  expenses      LotExpense[]
}

enum CookingStatus {
  ACTIVA
  PAUSADA
  TERMINADA
}

enum CookingEventType {
  INICIO_COCCION
  INICIO_VAPOR
  TEMPERATURA
  MIELES_AMARGAS
  MIELES_DULCES
  BAJAR_VAPOR
  AUMENTAR_VAPOR
  SUSPENDER_VAPOR
  FIN_COCCION
  OBSERVACION
}

model Cooking {
  id          String @id @default(cuid())
  lotId       String
  equipmentId String

  agaveKg Float
  status  CookingStatus @default(ACTIVA)

  startedAt  DateTime  @default(now())
  finishedAt DateTime?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lot       Lot            @relation(fields: [lotId], references: [id])
  equipment Equipment      @relation(fields: [equipmentId], references: [id])
  events    CookingEvent[]
}

model CookingEvent {
  id        String @id @default(cuid())
  cookingId String

  type              CookingEventType
  temperatureTop    Float?
  temperatureMiddle Float?
  temperatureBottom Float?

  liters      Float?
  ph          Float?
  brix        Float?
  temperature Float?

  notes     String?
  createdAt DateTime @default(now())

  cooking Cooking @relation(fields: [cookingId], references: [id])
}

enum MillingStatus {
  ACTIVA
  PAUSADA
  TERMINADA
}

enum MillingEventType {
  INICIO_MOLIENDA
  REGISTRO_BRIX
  REGISTRO_PH
  REGISTRO_TEMPERATURA
  AGREGAR_AGUA
  CAMBIO_PRENSA
  LAVADO_BAGAZO
  REGISTRO_BAGAZO
  FIN_MOLIENDA
  OBSERVACION
}

model Milling {
  id          String @id @default(cuid())
  lotId       String
  equipmentId String

  status   MillingStatus @default(ACTIVA)
  operator String?

  cookedKg            Float
  waterLiters         Float?
  mashLiters          Float?
  bagasseKg           Float?
  brix                Float?
  ph                  Float?
  temperature         Float?
  pressPasses         Int?
  washBagasse         Boolean @default(false)
  washRecoveredLiters Float?
  observations        String?

  startedAt  DateTime  @default(now())
  finishedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lot       Lot            @relation(fields: [lotId], references: [id])
  equipment Equipment      @relation(fields: [equipmentId], references: [id])
  events    MillingEvent[]
}

model MillingEvent {
  id        String @id @default(cuid())
  millingId String

  type  MillingEventType
  value Float?

  brix                Float?
  ph                  Float?
  temperature         Float?
  waterLiters         Float?
  bagasseKg           Float?
  washRecoveredLiters Float?
  pressPasses         Int?

  notes     String?
  createdAt DateTime @default(now())

  milling Milling @relation(fields: [millingId], references: [id])
}

model Fermentation {
  id String @id @default(cuid())

  lotId String
  lot   Lot    @relation(fields: [lotId], references: [id])

  tank String

  mustLiters Float

  initialBrix        Float
  initialPh          Float
  initialTemperature Float

  yeast String?

  inoculatedAt DateTime

  status FermentationStatus @default(ACTIVA)

  startedAt  DateTime  @default(now())
  finishedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  readings FermentationReading[]
}

model FermentationReading {
  id String @id @default(cuid())

  fermentationId String
  fermentation   Fermentation @relation(fields: [fermentationId], references: [id])

  brix          Float?
  ph            Float?
  temperature   Float?
  alcohol       Float?
  saccharometer Float?

  citricAcidGrams  Float?
  bicarbonateGrams Float?

  heated         Boolean @default(false)
  heatingMinutes Int?

  notes String?

  createdAt DateTime @default(now())
}

enum FermentationStatus {
  ACTIVA
  TERMINADA
}

enum DistillationStatus {
  ACTIVA
  TERMINADA
}

enum DistillationType {
  DESTROZADO
  RECTIFICACION
}

enum DistillationEventType {
  INICIO_CALENTAMIENTO
  TEMPERATURA
  ALCOHOL
  LITROS
  CORTE_CABEZAS
  INICIO_CORAZON
  FIN_CORAZON
  INICIO_COLAS
  FIN_DESTILACION
  OBSERVACION
}

model Distillation {
  id String @id @default(cuid())

  lotId String
  lot   Lot    @relation(fields: [lotId], references: [id])

  equipmentId String
  equipment   Equipment @relation(fields: [equipmentId], references: [id])

  type DistillationType

  loadedLiters   Float
  initialAlcohol Float?

  headsLiters Float?
  heartLiters Float?
  tailsLiters Float?

  finalAlcohol Float?

  status DistillationStatus @default(ACTIVA)

  startedAt  DateTime  @default(now())
  finishedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events DistillationEvent[]
}

model DistillationEvent {
  id String @id @default(cuid())

  distillationId String
  distillation   Distillation @relation(fields: [distillationId], references: [id])

  type DistillationEventType

  temperature       Float?
  alcohol           Float?
  liters            Float?
  outputTemperature Float?
  alcoholCorrected  Float?
  notes             String?

  createdAt DateTime @default(now())
}

model LotExpense {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  lotId String
  lot   Lot    @relation(fields: [lotId], references: [id], onDelete: Cascade)

  category String
  concept  String
  amount   Float

  notes String?

  @@index([lotId])
}
