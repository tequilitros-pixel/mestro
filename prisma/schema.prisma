generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                        String                 @id @default(cuid())
  name                      String
  username                  String                 @unique
  email                     String?                @unique
  password                  String
  role                      UserRole
  active                    Boolean                @default(true)
  createdAt                 DateTime               @default(now())
  updatedAt                 DateTime               @updatedAt
  lastLogin                 DateTime?
  cookingsFinished          Cooking[]              @relation("CookingFinishedBy")
  distillationsFinished     Distillation[]         @relation("DistillationFinishedBy")
  fermentationsFinished     Fermentation[]         @relation("FermentationFinishedBy")
  liquorBatchesCreated      LiquorBatch[]          @relation("LiquorBatchCreatedBy")
  liquorBatchesFinished     LiquorBatch[]          @relation("LiquorBatchFinishedBy")
  liquorBottlesSold         LiquorBottle[]         @relation("LiquorBottleSoldBy")
  liquorBottleMovements     LiquorBottleMovement[] @relation("LiquorBottleMovementCreatedBy")
  liquorBatchsPaused        LiquorBatch[]          @relation("LiquorBatchPausedBy")
  liquorEventsCreated       LiquorBatchEvent[]     @relation("LiquorBatchEventCreatedBy")
  liquorBatchStepsCompleted LiquorBatchStep[]      @relation("LiquorBatchStepCompletedBy")
  liquorBottlingsCreated    LiquorBottling[]       @relation("LiquorBottlingCreatedBy")
  liquorBottlingsFinished   LiquorBottling[]       @relation("LiquorBottlingFinishedBy")
  liquorProductsCreated     LiquorProduct[]        @relation("LiquorProductCreatedBy")
  liquorRecipesCreated      LiquorRecipe[]         @relation("LiquorRecipeCreatedBy")
  lots                      Lot[]
  branches                  UserBranch[]
  cashCutsResponsible       CashCut[]              @relation("CashCutResponsible")
  cashCutsCreated           CashCut[]              @relation("CashCutCreatedBy")
  cashCutsUpdated           CashCut[]              @relation("CashCutUpdatedBy")
  cashOutflowsAuthorized    CashOutflow[]          @relation("CashOutflowAuthorizedBy")
  cashCutAuditEntries       CashCutAuditEntry[]    @relation("CashCutAuditBy")

  millingsFinished   Milling[]           @relation("MillingFinishedBy")
  millingDischarges  MillingDischarge[]
  pushSubscriptions  PushSubscription[]
  passwordResetCodes PasswordResetCode[]
}

model Equipment {
  id                String             @id @default(cuid())
  name              String
  type              EquipmentType
  status            EquipmentStatus    @default(DISPONIBLE)
  capacity          Float
  currentLoad       Float              @default(0)
  unit              String
  location          String?
  active            Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  cookings          Cooking[]
  distillations     Distillation[]
  millings          Milling[]
  millingDischarges MillingDischarge[]
}

model Lot {
  id            String         @id @default(cuid())
  code          String         @unique
  stage         LotStage
  agaveKg       Float
  art           Float?
  startedAt     DateTime
  finishedAt    DateTime?
  observations  String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  ownerId       String
  cookings      Cooking[]
  distillations Distillation[]
  fermentations Fermentation[]
  owner         User           @relation(fields: [ownerId], references: [id])
  expenses      LotExpense[]
  millings      Milling[]
}

model Cooking {
  id                    String         @id @default(cuid())
  lotId                 String
  equipmentId           String
  agaveKg               Float
  status                CookingStatus  @default(ACTIVA)
  startedAt             DateTime       @default(now())
  finishedAt            DateTime?
  notes                 String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  closureCode           String?        @unique
  finalAgaveKg          Float?
  finalNotes            String?
  finalSweetHoneyBrix   Float?
  finalSweetHoneyLiters Float?
  finishedById          String?
  equipment             Equipment      @relation(fields: [equipmentId], references: [id])
  finishedBy            User?          @relation("CookingFinishedBy", fields: [finishedById], references: [id])
  lot                   Lot            @relation(fields: [lotId], references: [id])
  events                CookingEvent[]

  @@index([lotId])
  @@index([equipmentId])
  @@index([finishedById])
}

model CookingEvent {
  id                String           @id @default(cuid())
  cookingId         String
  type              CookingEventType
  temperatureTop    Float?
  temperatureMiddle Float?
  temperatureBottom Float?
  liters            Float?
  ph                Float?
  brix              Float?
  temperature       Float?
  notes             String?
  createdAt         DateTime         @default(now())
  cooking           Cooking          @relation(fields: [cookingId], references: [id])

  @@index([cookingId])
}

model Milling {
  id                  String             @id @default(cuid())
  lotId               String
  equipmentId         String
  status              MillingStatus      @default(ACTIVA)
  operator            String?
  cookedKg            Float
  waterLiters         Float?
  mashLiters          Float?
  bagasseKg           Float?
  brix                Float?
  ph                  Float?
  temperature         Float?
  pressPasses         Int?
  washBagasse         Boolean            @default(false)
  washRecoveredLiters Float?
  observations        String?
  startedAt           DateTime           @default(now())
  finishedAt          DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  closureCode         String?            @unique
  finalAverageBrix    Float?
  finalAveragePh      Float?
  finalAverageTemp    Float?
  finalBagasseKg      Float?
  finalMashLiters     Float?
  finalNotes          String?
  finalPressPasses    Int?
  finalWaterLiters    Float?
  finishedById        String?
  equipment           Equipment          @relation(fields: [equipmentId], references: [id])
  finishedBy          User?              @relation("MillingFinishedBy", fields: [finishedById], references: [id])
  lot                 Lot                @relation(fields: [lotId], references: [id])
  discharges          MillingDischarge[]
  events              MillingEvent[]

  @@index([lotId])
  @@index([equipmentId])
  @@index([finishedById])
}

model MillingEvent {
  id                  String           @id @default(cuid())
  millingId           String
  type                MillingEventType
  value               Float?
  brix                Float?
  ph                  Float?
  temperature         Float?
  waterLiters         Float?
  bagasseKg           Float?
  washRecoveredLiters Float?
  pressPasses         Int?
  notes               String?
  createdAt           DateTime         @default(now())
  milling             Milling          @relation(fields: [millingId], references: [id])

  @@index([millingId])
}

model Fermentation {
  id                 String                @id @default(cuid())
  lotId              String
  tank               String
  mustLiters         Float
  initialBrix        Float
  initialPh          Float
  initialTemperature Float
  yeast              String?
  inoculatedAt       DateTime
  status             FermentationStatus    @default(ACTIVA)
  startedAt          DateTime              @default(now())
  finishedAt         DateTime?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  closureCode        String?               @unique
  finalAlcohol       Float?
  finalBrix          Float?
  finalNotes         String?
  finalPh            Float?
  finishedById       String?
  finishedBy         User?                 @relation("FermentationFinishedBy", fields: [finishedById], references: [id])
  lot                Lot                   @relation(fields: [lotId], references: [id])
  readings           FermentationReading[]

  @@index([lotId])
  @@index([finishedById])
}

model FermentationReading {
  id               String       @id @default(cuid())
  fermentationId   String
  brix             Float?
  ph               Float?
  temperature      Float?
  alcohol          Float?
  saccharometer    Float?
  citricAcidGrams  Float?
  bicarbonateGrams Float?
  heated           Boolean      @default(false)
  heatingMinutes   Int?
  notes            String?
  createdAt        DateTime     @default(now())
  fermentation     Fermentation @relation(fields: [fermentationId], references: [id])

  @@index([fermentationId])
}

model Distillation {
  id               String              @id @default(cuid())
  lotId            String
  equipmentId      String
  type             DistillationType
  loadedLiters     Float
  initialAlcohol   Float?
  headsLiters      Float?
  heartLiters      Float?
  tailsLiters      Float?
  finalAlcohol     Float?
  status           DistillationStatus  @default(ACTIVA)
  startedAt        DateTime            @default(now())
  finishedAt       DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  closureCode      String?             @unique
  finalHeadsLiters Float?
  finalHeartLiters Float?
  finalLiters      Float?
  finalNotes       String?
  finalTailsLiters Float?
  finishedById     String?
  equipment        Equipment           @relation(fields: [equipmentId], references: [id])
  finishedBy       User?               @relation("DistillationFinishedBy", fields: [finishedById], references: [id])
  lot              Lot                 @relation(fields: [lotId], references: [id])
  events           DistillationEvent[]

  @@index([lotId])
  @@index([equipmentId])
  @@index([finishedById])
}

model DistillationEvent {
  id                String                @id @default(cuid())
  distillationId    String
  type              DistillationEventType
  temperature       Float?
  alcohol           Float?
  liters            Float?
  outputTemperature Float?
  alcoholCorrected  Float?
  notes             String?
  createdAt         DateTime              @default(now())
  distillation      Distillation          @relation(fields: [distillationId], references: [id])

  @@index([distillationId])
}

model LotExpense {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  lotId     String
  category  String
  concept   String
  amount    Float
  notes     String?
  lot       Lot      @relation(fields: [lotId], references: [id], onDelete: Cascade)

  @@index([lotId])
}

model MillingDischarge {
  id              String     @id @default(cuid())
  millingId       String
  tankId          String?
  litersRecovered Float
  brix            Float
  ph              Float
  temperature     Float
  notes           String?
  createdById     String?
  createdAt       DateTime   @default(now())
  createdBy       User?      @relation(fields: [createdById], references: [id])
  milling         Milling    @relation(fields: [millingId], references: [id], onDelete: Cascade)
  tank            Equipment? @relation(fields: [tankId], references: [id])

  @@index([millingId])
  @@index([tankId])
  @@index([createdById])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model RawMaterial {
  id String @id @default(cuid())

  code String @unique
  name String @unique

  category    String?
  description String?

  baseUnit String

  currentStock Float @default(0)
  minimumStock Float @default(0)

  averageCost Float?

  active Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  recipeIngredients LiquorRecipeIngredient[]

  @@index([active])
  @@index([category])
}

model LiquorProduct {
  id             String  @id @default(cuid())
  name           String  @unique
  slug           String  @unique
  prefix         String  @unique
  description    String?
  icon           String?
  defaultAlcohol Float?

  // Configuración de caducidad
  defaultShelfLifeDays  Int?
  yellowAlertDays       Int     @default(30)
  redAlertDays          Int     @default(7)
  showExpirationOnLabel Boolean @default(true)

  // Configuración de trazabilidad
  requiresQr           Boolean @default(true)
  requiresSerialNumber Boolean @default(true)

  active      Boolean  @default(true)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  batches   LiquorBatch[]
  createdBy User?          @relation("LiquorProductCreatedBy", fields: [createdById], references: [id])
  recipes   LiquorRecipe[]

  @@index([createdById])
  @@index([active])
}

/// *
///  * Una misma clase de licor puede tener varias versiones de receta.
///  * Ejemplo:
///  * Zarzamora V1
///  * Zarzamora V2
///  * Zarzamora V3
///  * Los lotes anteriores conservan la receta que utilizaron.
model LiquorRecipe {
  id            String                   @id @default(cuid())
  productId     String
  name          String
  version       Int
  targetLiters  Float?
  targetAlcohol Float?
  instructions  String?
  notes         String?
  active        Boolean                  @default(true)
  createdById   String?
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
  batches       LiquorBatch[]
  createdBy     User?                    @relation("LiquorRecipeCreatedBy", fields: [createdById], references: [id])
  product       LiquorProduct            @relation(fields: [productId], references: [id])
  ingredients   LiquorRecipeIngredient[]
  steps         LiquorRecipeStep[]

  @@unique([productId, version])
  @@index([productId])
  @@index([createdById])
  @@index([active])
}

model LiquorRecipeStep {
  id                 String                  @id @default(cuid())
  recipeId           String
  position           Int
  type               LiquorStepType
  title              String
  instruction        String?
  actions            String[]
  checks             String[]
  recipeIngredientId String?
  durationMinutes    Int?
  minimumMinutes     Int?
  maximumMinutes     Int?
  measurementLabel   String?
  measurementUnit    String?
  minimumValue       Float?
  maximumValue       Float?
  required           Boolean                 @default(true)
  active             Boolean                 @default(true)
  notes              String?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  batchSteps         LiquorBatchStep[]
  recipe             LiquorRecipe            @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  recipeIngredient   LiquorRecipeIngredient? @relation(fields: [recipeIngredientId], references: [id])

  @@unique([recipeId, position])
  @@index([recipeId])
  @@index([recipeIngredientId])
  @@index([type])
}

/// *
///  * Ingredientes oficiales de cada versión de receta.
model LiquorRecipeIngredient {
  id String @id @default(cuid())

  recipeId String
  recipe   LiquorRecipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  name String

  rawMaterialId String?
  rawMaterial   RawMaterial? @relation(fields: [rawMaterialId], references: [id], onDelete: SetNull)

  quantity Float
  unit     String

  position Int     @default(0)
  optional Boolean @default(false)

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  batchIngredients LiquorBatchIngredient[]
  recipeSteps      LiquorRecipeStep[]

  @@index([recipeId])
  @@index([rawMaterialId])
  @@index([position])
}

/// *
///  * Cada elaboración física de un licor.
///  * El campo sequence mantiene el consecutivo permanente global:
///  * LZ-15-07-2026-001
///  * LM-16-07-2026-002
///  * LC-18-07-2026-003
model LiquorBatch {
  id                   String                  @id @default(cuid())
  code                 String                  @unique
  sequence             Int                     @unique
  productId            String
  recipeId             String
  status               LiquorBatchStatus       @default(PLANEADO)
  plannedLiters        Float
  actualLiters         Float?
  initialAlcohol       Float?
  finalAlcohol         Float?
  productionDate       DateTime                @default(now())
  expirationDate       DateTime?
  qualityStatus        LiquorQualityStatus     @default(PENDIENTE)
  startedAt            DateTime?
  finishedAt           DateTime?
  closureCode          String?                 @unique
  observations         String?
  finalNotes           String?
  createdById          String
  finishedById         String?
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  pauseNotes           String?
  pauseReason          String?
  pausedAt             DateTime?
  pausedById           String?
  createdBy            User                    @relation("LiquorBatchCreatedBy", fields: [createdById], references: [id])
  finishedBy           User?                   @relation("LiquorBatchFinishedBy", fields: [finishedById], references: [id])
  pausedBy             User?                   @relation("LiquorBatchPausedBy", fields: [pausedById], references: [id])
  product              LiquorProduct           @relation(fields: [productId], references: [id])
  recipe               LiquorRecipe            @relation(fields: [recipeId], references: [id])
  events               LiquorBatchEvent[]
  executionIngredients LiquorBatchIngredient[]
  steps                LiquorBatchStep[]
  bottlings            LiquorBottling[]

  @@index([productId])
  @@index([recipeId])
  @@index([status])
  @@index([qualityStatus])
  @@index([productionDate])
  @@index([createdById])
  @@index([finishedById])
}

/// *
///  * Bitácora completa de elaboración.
model LiquorBatchEvent {
  id                 String               @id @default(cuid())
  batchId            String
  type               LiquorBatchEventType
  temperature        Float?
  alcohol            Float?
  brix               Float?
  ph                 Float?
  liters             Float?
  ingredientName     String?
  ingredientQuantity Float?
  ingredientUnit     String?
  qualityStatus      LiquorQualityStatus?
  notes              String?
  createdById        String?
  createdAt          DateTime             @default(now())
  batch              LiquorBatch          @relation(fields: [batchId], references: [id], onDelete: Cascade)
  createdBy          User?                @relation("LiquorBatchEventCreatedBy", fields: [createdById], references: [id])

  @@index([batchId])
  @@index([type])
  @@index([createdById])
  @@index([createdAt])
}

model LiquorBatchIngredient {
  id                 String                  @id @default(cuid())
  batchId            String
  recipeIngredientId String?
  name               String
  baseQuantity       Float
  scaledQuantity     Float
  unit               String
  completed          Boolean                 @default(false)
  actualQuantity     Float?
  completedAt        DateTime?
  notes              String?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  batch              LiquorBatch             @relation(fields: [batchId], references: [id], onDelete: Cascade)
  recipeIngredient   LiquorRecipeIngredient? @relation(fields: [recipeIngredientId], references: [id])
  batchSteps         LiquorBatchStep[]

  @@index([batchId])
  @@index([recipeIngredientId])
}

model LiquorBatchStep {
  id                     String                 @id @default(cuid())
  batchId                String
  recipeStepId           String?
  position               Int
  type                   LiquorStepType
  status                 LiquorBatchStepStatus  @default(PENDIENTE)
  title                  String
  instruction            String?
  actions                String[]
  checks                 String[]
  completedActionIndexes Int[]
  completedCheckIndexes  Int[]
  batchIngredientId      String?
  plannedQuantity        Float?
  actualQuantity         Float?
  unit                   String?
  durationMinutes        Int?
  minimumMinutes         Int?
  maximumMinutes         Int?
  actualMinutes          Int?
  measurementLabel       String?
  measurementUnit        String?
  minimumValue           Float?
  maximumValue           Float?
  measuredValue          Float?
  validationPassed       Boolean?
  startedAt              DateTime?
  completedAt            DateTime?
  completedById          String?
  observations           String?
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  batch                  LiquorBatch            @relation(fields: [batchId], references: [id], onDelete: Cascade)
  batchIngredient        LiquorBatchIngredient? @relation(fields: [batchIngredientId], references: [id])
  completedBy            User?                  @relation("LiquorBatchStepCompletedBy", fields: [completedById], references: [id])
  recipeStep             LiquorRecipeStep?      @relation(fields: [recipeStepId], references: [id])

  @@unique([batchId, position])
  @@index([batchId])
  @@index([recipeStepId])
  @@index([batchIngredientId])
  @@index([status])
  @@index([completedById])
}

model LiquorBottling {
  id              String               @id @default(cuid())
  code            String               @unique
  batchId         String
  status          LiquorBottlingStatus @default(PLANEADO)
  bottleSizeMl    Int
  plannedBottles  Int?
  producedBottles Int                  @default(0)
  rejectedBottles Int                  @default(0)
  litersUsed      Float?
  lossLiters      Float?
  bottledAt       DateTime?
  expirationDate  DateTime?
  startedAt       DateTime?
  finishedAt      DateTime?
  notes           String?
  createdById     String
  finishedById    String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  bottles         LiquorBottle[]
  batch           LiquorBatch          @relation(fields: [batchId], references: [id])
  createdBy       User                 @relation("LiquorBottlingCreatedBy", fields: [createdById], references: [id])
  finishedBy      User?                @relation("LiquorBottlingFinishedBy", fields: [finishedById], references: [id])

  @@index([batchId])
  @@index([status])
  @@index([createdById])
  @@index([finishedById])
  @@index([bottledAt])
}

/// *
///  * Cada botella individual tendrá identidad propia y un QR único.
model LiquorBottle {
  id           String @id @default(cuid())
  bottlingId   String
  code         String @unique
  serialNumber Int
  qrToken      String @unique @default(cuid())

  // Se agrega inicialmente como opcional para una migración segura.
  authenticityCode String? @unique

  status LiquorBottleStatus @default(DISPONIBLE)

  // Fechas propias de la botella
  manufacturedAt DateTime?
  bottledAt      DateTime
  expirationDate DateTime?

  // Copia histórica de las reglas aplicadas al embotellar
  shelfLifeDays         Int?
  yellowAlertDays       Int?
  redAlertDays          Int?
  showExpirationOnLabel Boolean @default(true)

  // Ubicación actual
  branchId        String?
  currentLocation String?

  // Venta y retiro
  reservedAt DateTime?
  soldAt     DateTime?
  soldById   String?
  removedAt  DateTime?

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bottling LiquorBottling @relation(fields: [bottlingId], references: [id], onDelete: Cascade)
  branch   Branch?        @relation(fields: [branchId], references: [id], onDelete: SetNull)
  soldBy   User?          @relation("LiquorBottleSoldBy", fields: [soldById], references: [id], onDelete: SetNull)

  movements LiquorBottleMovement[]

  @@unique([bottlingId, serialNumber])
  @@index([bottlingId])
  @@index([status])
  @@index([expirationDate])
  @@index([branchId])
  @@index([soldAt])
  @@index([soldById])
  @@index([manufacturedAt])
}

model LiquorBottleMovement {
  id       String                   @id @default(cuid())
  bottleId String
  type     LiquorBottleMovementType

  // Relaciones formales con sucursales
  fromBranchId String?
  toBranchId   String?

  // Campos anteriores conservados temporalmente
  fromLocation String?
  toLocation   String?

  userId    String?
  notes     String?
  createdAt DateTime @default(now())

  bottle     LiquorBottle @relation(fields: [bottleId], references: [id], onDelete: Cascade)
  fromBranch Branch?      @relation("LiquorMovementFromBranch", fields: [fromBranchId], references: [id], onDelete: SetNull)
  toBranch   Branch?      @relation("LiquorMovementToBranch", fields: [toBranchId], references: [id], onDelete: SetNull)
  user       User?        @relation("LiquorBottleMovementCreatedBy", fields: [userId], references: [id], onDelete: SetNull)

  @@index([bottleId])
  @@index([type])
  @@index([userId])
  @@index([fromBranchId])
  @@index([toBranchId])
  @@index([createdAt])
}

model Branch {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  address   String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users               UserBranch[]
  cashCuts            CashCut[]
  liquorBottles       LiquorBottle[]
  liquorMovementsFrom LiquorBottleMovement[] @relation("LiquorMovementFromBranch")
  liquorMovementsTo   LiquorBottleMovement[] @relation("LiquorMovementToBranch")

  @@index([active])
}

model UserBranch {
  id       String @id @default(cuid())
  userId   String
  branchId String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, branchId])
  @@index([userId])
  @@index([branchId])
}

model CashCut {
  id       String @id @default(cuid())
  code     String @unique
  branchId String
  branch   Branch @relation(fields: [branchId], references: [id])

  responsibleId String
  responsible   User   @relation("CashCutResponsible", fields: [responsibleId], references: [id])

  date     DateTime
  openedAt DateTime      @default(now())
  closedAt DateTime?
  status   CashCutStatus @default(ABIERTO)

  startingFund Float
  nextFund     Float?

  cashCounted  Float?
  cashExpected Float?
  difference   Float?

  envelopeAmount Float?
  envelopeNumber String?
  envelopeNotes  String?

  totalSales       Float?
  totalOutflows    Float?
  totalInflows     Float?
  totalCostOfGoods Float?
  netProfit        Float?

  notes String?

  createdById String
  createdBy   User    @relation("CashCutCreatedBy", fields: [createdById], references: [id])
  updatedById String?
  updatedBy   User?   @relation("CashCutUpdatedBy", fields: [updatedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  salesByMethod CashSalePayment[]
  outflows      CashOutflow[]
  inflows       CashInflow[]
  evidences     CashCutEvidence[]
  auditEntries  CashCutAuditEntry[]

  @@index([branchId])
  @@index([responsibleId])
  @@index([createdById])
  @@index([status])
  @@index([date])
}

enum CashCutStatus {
  ABIERTO
  CERRADO
  AUDITADO
}

model CashSalePayment {
  id        String  @id @default(cuid())
  cashCutId String
  cashCut   CashCut @relation(fields: [cashCutId], references: [id], onDelete: Cascade)

  method PaymentMethod
  amount Float
  notes  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cashCutId, method])
  @@index([cashCutId])
}

enum PaymentMethod {
  EFECTIVO
  TARJETA
  TRANSFERENCIA
  DIDI
  UBER
  RAPPI
  VALES
  OTRO
}

model CashOutflow {
  id        String  @id @default(cuid())
  cashCutId String
  cashCut   CashCut @relation(fields: [cashCutId], references: [id], onDelete: Cascade)

  concept         String
  category        String
  amount          Float
  authorizedById  String?
  authorizedBy    User?   @relation("CashOutflowAuthorizedBy", fields: [authorizedById], references: [id])
  notes           String?
  receiptPhotoUrl String?

  occurredAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([cashCutId])
  @@index([authorizedById])
  @@index([category])
}

model CashInflow {
  id        String  @id @default(cuid())
  cashCutId String
  cashCut   CashCut @relation(fields: [cashCutId], references: [id], onDelete: Cascade)

  type   CashInflowType
  amount Float
  notes  String?

  occurredAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([cashCutId])
}

enum CashInflowType {
  CAMBIO_RECIBIDO
  REEMBOLSO
  AJUSTE
  PRESTAMO
  OTRO
}

model CashCutEvidence {
  id        String  @id @default(cuid())
  cashCutId String
  cashCut   CashCut @relation(fields: [cashCutId], references: [id], onDelete: Cascade)

  type  CashEvidenceType
  url   String
  notes String?

  createdAt DateTime @default(now())

  @@index([cashCutId])
  @@index([type])
}

enum CashEvidenceType {
  DINERO_CONTADO
  SOBRE
  TICKET
  NOTA
  FACTURA
  OTRO
}

model CashCutAuditEntry {
  id        String  @id @default(cuid())
  cashCutId String
  cashCut   CashCut @relation(fields: [cashCutId], references: [id], onDelete: Cascade)

  action   String
  field    String?
  oldValue String?
  newValue String?

  userId String
  user   User   @relation("CashCutAuditBy", fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@index([cashCutId])
  @@index([userId])
}

