generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  OPERATOR
}

enum EquipmentType {
  HORNO
  DESGARRADORA
  PRENSA
  TINA
  ALAMBIQUE
  BOMBA
  TANQUE
  CALDERA
  OTRO
}

enum EquipmentStatus {
  DISPONIBLE
  OPERANDO
  ESPERANDO
  LAVADO
  MANTENIMIENTO
}

enum LotStage {
  RECEPCION
  COCCION
  MOLIENDA
  FERMENTACION
  DESTILACION
  RECTIFICACION
  TERMINADO
}

model User {
  id       String   @id @default(cuid())
  name     String
  username String   @unique
  email    String?  @unique
  password String
  role     UserRole
  active   Boolean  @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  lastLogin DateTime?

  lots                  Lot[]
  millingDischarges     MillingDischarge[]
  pushSubscriptions     PushSubscription[]
  cookingsFinished      Cooking[]          @relation("CookingFinishedBy")
  fermentationsFinished Fermentation[]     @relation("FermentationFinishedBy")
  distillationsFinished Distillation[]     @relation("DistillationFinishedBy")
  millingsFinished      Milling[]          @relation("MillingFinishedBy")
}

model Equipment {
  id     String          @id @default(cuid())
  name   String
  type   EquipmentType
  status EquipmentStatus @default(DISPONIBLE)

  capacity    Float
  currentLoad Float   @default(0)
  unit        String
  location    String?
  active      Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cookings          Cooking[]
  millings          Milling[]
  distillations     Distillation[]
  millingDischarges MillingDischarge[]
}

model Lot {
  id    String   @id @default(cuid())
  code  String   @unique
  stage LotStage

  agaveKg      Float
  art          Float?
  startedAt    DateTime
  finishedAt   DateTime?
  observations String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id])

  cookings      Cooking[]
  millings      Milling[]
  fermentations Fermentation[]
  distillations Distillation[]
  expenses      LotExpense[]
}

enum CookingStatus {
  ACTIVA
  PAUSADA
  TERMINADA
}

enum CookingEventType {
  INICIO_COCCION
  INICIO_VAPOR
  TEMPERATURA
  MIELES_AMARGAS
  MIELES_DULCES
  BAJAR_VAPOR
  AUMENTAR_VAPOR
  SUSPENDER_VAPOR
  FIN_COCCION
  OBSERVACION
}

model Cooking {
  id          String @id @default(cuid())
  lotId       String
  equipmentId String

  agaveKg Float
  status  CookingStatus @default(ACTIVA)

  startedAt  DateTime  @default(now())
  finishedAt DateTime?

  notes String?

  finalAgaveKg          Float?
  finalSweetHoneyLiters Float?
  finalSweetHoneyBrix   Float?
  finalNotes            String?

  closureCode String? @unique

  finishedById String?
  finishedBy   User?   @relation("CookingFinishedBy", fields: [finishedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lot       Lot            @relation(fields: [lotId], references: [id])
  equipment Equipment      @relation(fields: [equipmentId], references: [id])
  events    CookingEvent[]

  @@index([lotId])
  @@index([equipmentId])
  @@index([finishedById])
}

model CookingEvent {
  id        String @id @default(cuid())
  cookingId String

  type CookingEventType

  temperatureTop    Float?
  temperatureMiddle Float?
  temperatureBottom Float?

  liters      Float?
  ph          Float?
  brix        Float?
  temperature Float?

  notes     String?
  createdAt DateTime @default(now())

  cooking Cooking @relation(fields: [cookingId], references: [id])

  @@index([cookingId])
}

enum MillingStatus {
  ACTIVA
  PAUSADA
  TERMINADA
}

enum MillingEventType {
  INICIO_MOLIENDA
  REGISTRO_BRIX
  REGISTRO_PH
  REGISTRO_TEMPERATURA
  AGREGAR_AGUA
  CAMBIO_PRENSA
  LAVADO_BAGAZO
  REGISTRO_BAGAZO
  FIN_MOLIENDA
  OBSERVACION
}

model Milling {
  id          String @id @default(cuid())
  lotId       String
  equipmentId String

  status   MillingStatus @default(ACTIVA)
  operator String?

  cookedKg            Float
  waterLiters         Float?
  mashLiters          Float?
  bagasseKg           Float?
  brix                Float?
  ph                  Float?
  temperature         Float?
  pressPasses         Int?
  washBagasse         Boolean @default(false)
  washRecoveredLiters Float?
  observations        String?

  startedAt  DateTime  @default(now())
  finishedAt DateTime?

  finalMashLiters  Float?
  finalAverageBrix Float?
  finalAveragePh   Float?
  finalAverageTemp Float?
  finalBagasseKg   Float?
  finalWaterLiters Float?
  finalPressPasses Int?
  finalNotes       String?

  closureCode String? @unique

  finishedById String?
  finishedBy   User?   @relation("MillingFinishedBy", fields: [finishedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lot        Lot                @relation(fields: [lotId], references: [id])
  equipment  Equipment          @relation(fields: [equipmentId], references: [id])
  events     MillingEvent[]
  discharges MillingDischarge[]

  @@index([lotId])
  @@index([equipmentId])
  @@index([finishedById])
}

model MillingEvent {
  id        String @id @default(cuid())
  millingId String

  type  MillingEventType
  value Float?

  brix                Float?
  ph                  Float?
  temperature         Float?
  waterLiters         Float?
  bagasseKg           Float?
  washRecoveredLiters Float?
  pressPasses         Int?

  notes     String?
  createdAt DateTime @default(now())

  milling Milling @relation(fields: [millingId], references: [id])
}

enum FermentationStatus {
  ACTIVA
  TERMINADA
}

model Fermentation {
  id String @id @default(cuid())

  lotId String
  lot   Lot    @relation(fields: [lotId], references: [id])

  tank       String
  mustLiters Float

  initialBrix        Float
  initialPh          Float
  initialTemperature Float

  yeast String?

  inoculatedAt DateTime

  status FermentationStatus @default(ACTIVA)

  startedAt  DateTime  @default(now())
  finishedAt DateTime?

  finalBrix    Float?
  finalPh      Float?
  finalAlcohol Float?
  finalNotes   String?

  closureCode String? @unique

  finishedById String?
  finishedBy   User?   @relation("FermentationFinishedBy", fields: [finishedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  readings FermentationReading[]

  @@index([lotId])
  @@index([finishedById])
}

model FermentationReading {
  id String @id @default(cuid())

  fermentationId String
  fermentation   Fermentation @relation(fields: [fermentationId], references: [id])

  brix          Float?
  ph            Float?
  temperature   Float?
  alcohol       Float?
  saccharometer Float?

  citricAcidGrams  Float?
  bicarbonateGrams Float?

  heated         Boolean @default(false)
  heatingMinutes Int?

  notes String?

  createdAt DateTime @default(now())
}

enum DistillationStatus {
  ACTIVA
  TERMINADA
}

enum DistillationType {
  DESTROZADO
  RECTIFICACION
}

enum DistillationEventType {
  INICIO_CALENTAMIENTO
  TEMPERATURA
  ALCOHOL
  LITROS
  CORTE_CABEZAS
  INICIO_CORAZON
  FIN_CORAZON
  INICIO_COLAS
  FIN_DESTILACION
  OBSERVACION
}

model Distillation {
  id String @id @default(cuid())

  lotId String
  lot   Lot    @relation(fields: [lotId], references: [id])

  equipmentId String
  equipment   Equipment @relation(fields: [equipmentId], references: [id])

  type DistillationType

  loadedLiters   Float
  initialAlcohol Float?

  headsLiters Float?
  heartLiters Float?
  tailsLiters Float?

  finalAlcohol Float?

  finalLiters      Float?
  finalHeadsLiters Float?
  finalHeartLiters Float?
  finalTailsLiters Float?
  finalNotes       String?

  closureCode String? @unique

  finishedById String?
  finishedBy   User?   @relation("DistillationFinishedBy", fields: [finishedById], references: [id])

  status DistillationStatus @default(ACTIVA)

  startedAt  DateTime  @default(now())
  finishedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events DistillationEvent[]

  @@index([lotId])
  @@index([equipmentId])
  @@index([finishedById])
}

model DistillationEvent {
  id String @id @default(cuid())

  distillationId String
  distillation   Distillation @relation(fields: [distillationId], references: [id])

  type DistillationEventType

  temperature       Float?
  alcohol           Float?
  liters            Float?
  outputTemperature Float?
  alcoholCorrected  Float?
  notes             String?

  createdAt DateTime @default(now())

  @@index([distillationId])
}

model LotExpense {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  lotId String
  lot   Lot    @relation(fields: [lotId], references: [id], onDelete: Cascade)

  category String
  concept  String
  amount   Float

  notes String?

  @@index([lotId])
}

model MillingDischarge {
  id String @id @default(cuid())

  millingId String
  milling   Milling @relation(fields: [millingId], references: [id], onDelete: Cascade)

  tankId String?
  tank   Equipment? @relation(fields: [tankId], references: [id])

  litersRecovered Float
  brix            Float
  ph              Float
  temperature     Float

  notes String?

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id])

  createdAt DateTime @default(now())

  @@index([millingId])
  @@index([tankId])
}

model PushSubscription {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  endpoint String @unique
  p256dh   String
  auth     String

  createdAt DateTime @default(now())
}
