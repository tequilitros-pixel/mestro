generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  OPERATOR
}

enum EquipmentType {
  HORNO
  DESGARRADORA
  PRENSA
  TINA
  ALAMBIQUE
  BOMBA
  TANQUE
  CALDERA
  OTRO
}

enum EquipmentStatus {
  DISPONIBLE
  OPERANDO
  ESPERANDO
  LAVADO
  MANTENIMIENTO
}

enum LotStage {
  RECEPCION
  COCCION
  MOLIENDA
  FERMENTACION
  DESTILACION
  RECTIFICACION
  TERMINADO
}

enum CookingStatus {
  ACTIVA
  PAUSADA
  TERMINADA
}

enum CookingEventType {
  INICIO_COCCION
  INICIO_VAPOR
  TEMPERATURA
  MIELES_AMARGAS
  MIELES_DULCES
  BAJAR_VAPOR
  AUMENTAR_VAPOR
  SUSPENDER_VAPOR
  FIN_COCCION
  OBSERVACION
}

enum MillingStatus {
  ACTIVA
  PAUSADA
  TERMINADA
}

enum MillingEventType {
  INICIO_MOLIENDA
  REGISTRO_BRIX
  REGISTRO_PH
  REGISTRO_TEMPERATURA
  AGREGAR_AGUA
  CAMBIO_PRENSA
  LAVADO_BAGAZO
  REGISTRO_BAGAZO
  FIN_MOLIENDA
  OBSERVACION
}

enum FermentationStatus {
  ACTIVA
  TERMINADA
}

enum DistillationStatus {
  ACTIVA
  TERMINADA
}

enum DistillationType {
  DESTROZADO
  RECTIFICACION
}

enum DistillationEventType {
  INICIO_CALENTAMIENTO
  TEMPERATURA
  ALCOHOL
  LITROS
  CORTE_CABEZAS
  INICIO_CORAZON
  FIN_CORAZON
  INICIO_COLAS
  FIN_DESTILACION
  OBSERVACION
}

/**
 * ELABORACIÓN DE LICORES
 */

enum LiquorBatchStatus {
  PLANEADO
  EN_ELABORACION
  PAUSADO
  EN_REPOSO
  LISTO_PARA_EMBOTELLAR
  EMBOTELLANDO
  TERMINADO
  CANCELADO
}

enum LiquorBatchEventType {
  INICIO_ELABORACION
  INGREDIENTE_AGREGADO
  MEZCLADO
  MEDICION
  CORRECCION
  FILTRADO
  INICIO_REPOSO
  FIN_REPOSO
  CONTROL_CALIDAD
  OBSERVACION
  FIN_ELABORACION
}

enum LiquorQualityStatus {
  PENDIENTE
  APROBADO
  RECHAZADO
}

enum LiquorBottlingStatus {
  PLANEADO
  ACTIVO
  TERMINADO
  CANCELADO
}

enum LiquorBottleStatus {
  DISPONIBLE
  RESERVADA
  VENDIDA
  MERMA
  RETIRADA
}

enum LiquorStepType {
  PREPARATION
  INGREDIENT
  MIXING
  WAIT
  MEASUREMENT
  QUALITY_CHECK
  FINISH
}

enum LiquorBatchStepStatus {
  PENDIENTE
  EN_PROCESO
  COMPLETADO
  OMITIDO
}

enum LiquorBottleMovementType {
  CREADA
  RESERVADA
  LIBERADA
  TRASPASADA
  VENDIDA
  DEVUELTA
  MERMA
  RETIRADA
  AJUSTE
}

model User {
  id       String   @id @default(cuid())
  name     String
  username String   @unique
  email    String?  @unique
  password String
  role     UserRole
  active   Boolean  @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  lastLogin DateTime?

  lots              Lot[]
  millingDischarges MillingDischarge[]
  pushSubscriptions PushSubscription[]

  cookingsFinished      Cooking[]      @relation("CookingFinishedBy")
  millingsFinished      Milling[]      @relation("MillingFinishedBy")
  fermentationsFinished Fermentation[] @relation("FermentationFinishedBy")
  distillationsFinished Distillation[] @relation("DistillationFinishedBy")

  liquorProductsCreated LiquorProduct[]    @relation("LiquorProductCreatedBy")
  liquorRecipesCreated  LiquorRecipe[]     @relation("LiquorRecipeCreatedBy")
  liquorBatchesCreated  LiquorBatch[]      @relation("LiquorBatchCreatedBy")
  liquorBatchesFinished LiquorBatch[]      @relation("LiquorBatchFinishedBy")
  liquorEventsCreated   LiquorBatchEvent[] @relation("LiquorBatchEventCreatedBy")

  liquorBottlingsCreated  LiquorBottling[] @relation("LiquorBottlingCreatedBy")
  liquorBottlingsFinished LiquorBottling[] @relation("LiquorBottlingFinishedBy")
  liquorBatchsPaused      LiquorBatch[]    @relation("LiquorBatchPausedBy")

  liquorBatchStepsCompleted LiquorBatchStep[] @relation("LiquorBatchStepCompletedBy")
}

model Equipment {
  id     String          @id @default(cuid())
  name   String
  type   EquipmentType
  status EquipmentStatus @default(DISPONIBLE)

  capacity    Float
  currentLoad Float   @default(0)
  unit        String
  location    String?
  active      Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cookings          Cooking[]
  millings          Milling[]
  distillations     Distillation[]
  millingDischarges MillingDischarge[]
}

model Lot {
  id    String   @id @default(cuid())
  code  String   @unique
  stage LotStage

  agaveKg      Float
  art          Float?
  startedAt    DateTime
  finishedAt   DateTime?
  observations String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id])

  cookings      Cooking[]
  millings      Milling[]
  fermentations Fermentation[]
  distillations Distillation[]
  expenses      LotExpense[]
}

model Cooking {
  id          String @id @default(cuid())
  lotId       String
  equipmentId String

  agaveKg Float
  status  CookingStatus @default(ACTIVA)

  startedAt  DateTime  @default(now())
  finishedAt DateTime?

  notes String?

  finalAgaveKg          Float?
  finalSweetHoneyLiters Float?
  finalSweetHoneyBrix   Float?
  finalNotes            String?

  closureCode String? @unique

  finishedById String?
  finishedBy   User?   @relation("CookingFinishedBy", fields: [finishedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lot       Lot            @relation(fields: [lotId], references: [id])
  equipment Equipment      @relation(fields: [equipmentId], references: [id])
  events    CookingEvent[]

  @@index([lotId])
  @@index([equipmentId])
  @@index([finishedById])
}

model CookingEvent {
  id        String @id @default(cuid())
  cookingId String

  type CookingEventType

  temperatureTop    Float?
  temperatureMiddle Float?
  temperatureBottom Float?

  liters      Float?
  ph          Float?
  brix        Float?
  temperature Float?

  notes     String?
  createdAt DateTime @default(now())

  cooking Cooking @relation(fields: [cookingId], references: [id])

  @@index([cookingId])
}

model Milling {
  id          String @id @default(cuid())
  lotId       String
  equipmentId String

  status   MillingStatus @default(ACTIVA)
  operator String?

  cookedKg            Float
  waterLiters         Float?
  mashLiters          Float?
  bagasseKg           Float?
  brix                Float?
  ph                  Float?
  temperature         Float?
  pressPasses         Int?
  washBagasse         Boolean @default(false)
  washRecoveredLiters Float?
  observations        String?

  startedAt  DateTime  @default(now())
  finishedAt DateTime?

  finalMashLiters  Float?
  finalAverageBrix Float?
  finalAveragePh   Float?
  finalAverageTemp Float?
  finalBagasseKg   Float?
  finalWaterLiters Float?
  finalPressPasses Int?
  finalNotes       String?

  closureCode String? @unique

  finishedById String?
  finishedBy   User?   @relation("MillingFinishedBy", fields: [finishedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lot        Lot                @relation(fields: [lotId], references: [id])
  equipment  Equipment          @relation(fields: [equipmentId], references: [id])
  events     MillingEvent[]
  discharges MillingDischarge[]

  @@index([lotId])
  @@index([equipmentId])
  @@index([finishedById])
}

model MillingEvent {
  id        String @id @default(cuid())
  millingId String

  type  MillingEventType
  value Float?

  brix                Float?
  ph                  Float?
  temperature         Float?
  waterLiters         Float?
  bagasseKg           Float?
  washRecoveredLiters Float?
  pressPasses         Int?

  notes     String?
  createdAt DateTime @default(now())

  milling Milling @relation(fields: [millingId], references: [id])

  @@index([millingId])
}

model Fermentation {
  id String @id @default(cuid())

  lotId String
  lot   Lot    @relation(fields: [lotId], references: [id])

  tank       String
  mustLiters Float

  initialBrix        Float
  initialPh          Float
  initialTemperature Float

  yeast String?

  inoculatedAt DateTime

  status FermentationStatus @default(ACTIVA)

  startedAt  DateTime  @default(now())
  finishedAt DateTime?

  finalBrix    Float?
  finalPh      Float?
  finalAlcohol Float?
  finalNotes   String?

  closureCode String? @unique

  finishedById String?
  finishedBy   User?   @relation("FermentationFinishedBy", fields: [finishedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  readings FermentationReading[]

  @@index([lotId])
  @@index([finishedById])
}

model FermentationReading {
  id String @id @default(cuid())

  fermentationId String
  fermentation   Fermentation @relation(fields: [fermentationId], references: [id])

  brix          Float?
  ph            Float?
  temperature   Float?
  alcohol       Float?
  saccharometer Float?

  citricAcidGrams  Float?
  bicarbonateGrams Float?

  heated         Boolean @default(false)
  heatingMinutes Int?

  notes String?

  createdAt DateTime @default(now())

  @@index([fermentationId])
}

model Distillation {
  id String @id @default(cuid())

  lotId String
  lot   Lot    @relation(fields: [lotId], references: [id])

  equipmentId String
  equipment   Equipment @relation(fields: [equipmentId], references: [id])

  type DistillationType

  loadedLiters   Float
  initialAlcohol Float?

  headsLiters Float?
  heartLiters Float?
  tailsLiters Float?

  finalAlcohol Float?

  finalLiters      Float?
  finalHeadsLiters Float?
  finalHeartLiters Float?
  finalTailsLiters Float?
  finalNotes       String?

  closureCode String? @unique

  finishedById String?
  finishedBy   User?   @relation("DistillationFinishedBy", fields: [finishedById], references: [id])

  status DistillationStatus @default(ACTIVA)

  startedAt  DateTime  @default(now())
  finishedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events DistillationEvent[]

  @@index([lotId])
  @@index([equipmentId])
  @@index([finishedById])
}

model DistillationEvent {
  id String @id @default(cuid())

  distillationId String
  distillation   Distillation @relation(fields: [distillationId], references: [id])

  type DistillationEventType

  temperature       Float?
  alcohol           Float?
  liters            Float?
  outputTemperature Float?
  alcoholCorrected  Float?
  notes             String?

  createdAt DateTime @default(now())

  @@index([distillationId])
}

model LotExpense {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  lotId String
  lot   Lot    @relation(fields: [lotId], references: [id], onDelete: Cascade)

  category String
  concept  String
  amount   Float

  notes String?

  @@index([lotId])
}

model MillingDischarge {
  id String @id @default(cuid())

  millingId String
  milling   Milling @relation(fields: [millingId], references: [id], onDelete: Cascade)

  tankId String?
  tank   Equipment? @relation(fields: [tankId], references: [id])

  litersRecovered Float
  brix            Float
  ph              Float
  temperature     Float

  notes String?

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id])

  createdAt DateTime @default(now())

  @@index([millingId])
  @@index([tankId])
  @@index([createdById])
}

model PushSubscription {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  endpoint String @unique
  p256dh   String
  auth     String

  createdAt DateTime @default(now())

  @@index([userId])
}

/**
 * ============================================================
 * ELABORACIÓN DE LICORES
 * ============================================================
 */

/**
 * Representa un producto permanente:
 * Zarzamora, Mango, Café, Jamaica, Mojito, Granada,
 * Tequimiche, Sangría o Destilado para Coscorrón.
 * Al entrar a un producto se mostrará todo su historial.
 */
model LiquorProduct {
  id String @id @default(cuid())

  name   String @unique
  slug   String @unique
  prefix String @unique

  description String?
  icon        String?

  defaultAlcohol       Float?
  defaultShelfLifeDays Int?

  active Boolean @default(true)

  createdById String?
  createdBy   User?   @relation("LiquorProductCreatedBy", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  recipes LiquorRecipe[]
  batches LiquorBatch[]

  @@index([createdById])
  @@index([active])
}

/**
 * Una misma clase de licor puede tener varias versiones de receta.
 * Ejemplo:
 * Zarzamora V1
 * Zarzamora V2
 * Zarzamora V3
 * Los lotes anteriores conservan la receta que utilizaron.
 */
model LiquorRecipe {
  id String @id @default(cuid())

  productId String
  product   LiquorProduct @relation(fields: [productId], references: [id])

  name    String
  version Int

  targetLiters  Float?
  targetAlcohol Float?

  instructions String?
  notes        String?

  active Boolean @default(true)

  createdById String?
  createdBy   User?   @relation("LiquorRecipeCreatedBy", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ingredients LiquorRecipeIngredient[]
  steps       LiquorRecipeStep[]
  batches     LiquorBatch[]

  @@unique([productId, version])
  @@index([productId])
  @@index([createdById])
  @@index([active])
}

model LiquorRecipeStep {
  id String @id @default(cuid())

  recipeId String
  recipe   LiquorRecipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  position Int
  type     LiquorStepType

  title       String
  instruction String?

  actions String[]
  checks  String[]

  recipeIngredientId String?
  recipeIngredient   LiquorRecipeIngredient? @relation(fields: [recipeIngredientId], references: [id], onDelete: SetNull)

  durationMinutes Int?
  minimumMinutes  Int?
  maximumMinutes  Int?

  measurementLabel String?
  measurementUnit  String?
  minimumValue     Float?
  maximumValue     Float?

  required Boolean @default(true)
  active   Boolean @default(true)

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  batchSteps LiquorBatchStep[]

  @@unique([recipeId, position])
  @@index([recipeId])
  @@index([recipeIngredientId])
  @@index([type])
}

/**
 * Ingredientes oficiales de cada versión de receta.
 */
model LiquorRecipeIngredient {
  id String @id @default(cuid())

  recipeId String
  recipe   LiquorRecipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  name     String
  quantity Float
  unit     String

  position Int     @default(0)
  optional Boolean @default(false)

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  batchIngredients LiquorBatchIngredient[]
  recipeSteps      LiquorRecipeStep[]

  @@index([recipeId])
  @@index([position])
}

/**
 * Cada elaboración física de un licor.
 * El campo sequence mantiene el consecutivo permanente global:
 * LZ-15-07-2026-001
 * LM-16-07-2026-002
 * LC-18-07-2026-003
 */
model LiquorBatch {
  id String @id @default(cuid())

  code     String @unique
  sequence Int    @unique

  productId String
  product   LiquorProduct @relation(fields: [productId], references: [id])

  recipeId String
  recipe   LiquorRecipe @relation(fields: [recipeId], references: [id])

  status LiquorBatchStatus @default(PLANEADO)

  plannedLiters Float
  actualLiters  Float?

  initialAlcohol Float?
  finalAlcohol   Float?

  productionDate DateTime  @default(now())
  expirationDate DateTime?

  qualityStatus LiquorQualityStatus @default(PENDIENTE)

  startedAt  DateTime?
  finishedAt DateTime?

  closureCode String? @unique

  observations String?
  finalNotes   String?

  createdById String
  createdBy   User   @relation("LiquorBatchCreatedBy", fields: [createdById], references: [id])

  finishedById String?
  finishedBy   User?   @relation("LiquorBatchFinishedBy", fields: [finishedById], references: [id])

  pausedAt DateTime?

  pausedById String?

  pausedBy    User?   @relation("LiquorBatchPausedBy", fields: [pausedById], references: [id])
  pauseReason String?

  pauseNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events               LiquorBatchEvent[]
  bottlings            LiquorBottling[]
  executionIngredients LiquorBatchIngredient[]
  steps                LiquorBatchStep[]

  @@index([productId])
  @@index([recipeId])
  @@index([status])
  @@index([qualityStatus])
  @@index([productionDate])
  @@index([createdById])
  @@index([finishedById])
}

/**
 * Bitácora completa de elaboración.
 */
model LiquorBatchEvent {
  id String @id @default(cuid())

  batchId String
  batch   LiquorBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  type LiquorBatchEventType

  temperature Float?
  alcohol     Float?
  brix        Float?
  ph          Float?
  liters      Float?

  ingredientName     String?
  ingredientQuantity Float?
  ingredientUnit     String?

  qualityStatus LiquorQualityStatus?

  notes String?

  createdById String?
  createdBy   User?   @relation("LiquorBatchEventCreatedBy", fields: [createdById], references: [id])

  createdAt DateTime @default(now())

  @@index([batchId])
  @@index([type])
  @@index([createdById])
  @@index([createdAt])
}

/**
 * Cada corrida de embotellado.
 * Un lote puede embotellarse en distintas presentaciones:
 * 250 ml, 500 ml, 750 ml, 1 litro, 2 litros, etc.
 */

model LiquorBatchIngredient {
  id String @id @default(cuid())

  batchId String
  batch   LiquorBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  recipeIngredientId String?

  recipeIngredient LiquorRecipeIngredient? @relation(fields: [recipeIngredientId], references: [id])
  name             String

  baseQuantity   Float
  scaledQuantity Float
  unit           String

  completed      Boolean   @default(false)
  actualQuantity Float?
  completedAt    DateTime?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  batchSteps LiquorBatchStep[]

  @@index([batchId])
  @@index([recipeIngredientId])
}

model LiquorBatchStep {
  id String @id @default(cuid())

  batchId String
  batch   LiquorBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  recipeStepId String?
  recipeStep   LiquorRecipeStep? @relation(fields: [recipeStepId], references: [id], onDelete: SetNull)

  position Int
  type     LiquorStepType
  status   LiquorBatchStepStatus @default(PENDIENTE)

  title       String
  instruction String?

  actions String[]
  checks  String[]

  completedActionIndexes Int[]
  completedCheckIndexes  Int[]

  batchIngredientId String?
  batchIngredient   LiquorBatchIngredient? @relation(fields: [batchIngredientId], references: [id], onDelete: SetNull)

  plannedQuantity Float?
  actualQuantity  Float?
  unit            String?

  durationMinutes Int?
  minimumMinutes  Int?
  maximumMinutes  Int?
  actualMinutes   Int?

  measurementLabel String?
  measurementUnit  String?
  minimumValue     Float?
  maximumValue     Float?
  measuredValue    Float?

  validationPassed Boolean?

  startedAt   DateTime?
  completedAt DateTime?

  completedById String?
  completedBy   User?   @relation("LiquorBatchStepCompletedBy", fields: [completedById], references: [id])

  observations String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([batchId, position])
  @@index([batchId])
  @@index([recipeStepId])
  @@index([batchIngredientId])
  @@index([status])
  @@index([completedById])
}

model LiquorBottling {
  id String @id @default(cuid())

  code String @unique

  batchId String
  batch   LiquorBatch @relation(fields: [batchId], references: [id])

  status LiquorBottlingStatus @default(PLANEADO)

  bottleSizeMl Int

  plannedBottles  Int?
  producedBottles Int  @default(0)
  rejectedBottles Int  @default(0)

  litersUsed Float?
  lossLiters Float?

  bottledAt      DateTime?
  expirationDate DateTime?

  startedAt  DateTime?
  finishedAt DateTime?

  notes String?

  createdById String
  createdBy   User   @relation("LiquorBottlingCreatedBy", fields: [createdById], references: [id])

  finishedById String?
  finishedBy   User?   @relation("LiquorBottlingFinishedBy", fields: [finishedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bottles LiquorBottle[]

  @@index([batchId])
  @@index([status])
  @@index([createdById])
  @@index([finishedById])
  @@index([bottledAt])
}

/**
 * Cada botella individual tendrá identidad propia y un QR único.
 */
model LiquorBottle {
  id String @id @default(cuid())

  bottlingId String
  bottling   LiquorBottling @relation(fields: [bottlingId], references: [id], onDelete: Cascade)

  code         String @unique
  serialNumber Int

  qrToken String @unique @default(cuid())

  status LiquorBottleStatus @default(DISPONIBLE)

  bottledAt      DateTime
  expirationDate DateTime?

  currentLocation String?

  reservedAt DateTime?
  soldAt     DateTime?
  removedAt  DateTime?

  soldById String?
  branchId String?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  movements LiquorBottleMovement[]

  @@unique([bottlingId, serialNumber])
  @@index([bottlingId])
  @@index([status])
  @@index([expirationDate])
  @@index([currentLocation])
  @@index([soldAt])
  @@index([soldById])
  @@index([branchId])
}

model LiquorBottleMovement {
  id String @id @default(cuid())

  bottleId String
  bottle   LiquorBottle @relation(fields: [bottleId], references: [id], onDelete: Cascade)

  type LiquorBottleMovementType

  fromLocation String?
  toLocation   String?

  userId String?
  notes  String?

  createdAt DateTime @default(now())

  @@index([bottleId])
  @@index([type])
  @@index([userId])
  @@index([createdAt])
}
